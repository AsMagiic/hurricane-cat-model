# Claude Code internal files
.claude/

# Python bytecode
__pycache__/
*.pyc

# Large generated catalog outputs (produced by full simulation runs)
outputs/catalog/
outputs/hazard_catalog*.csv
outputs/event_loss_table*.csv

# Step 4+ simulation results (reproducible by seed; not committed)
results/*
!results/summary_metrics.csv

# Virtual environments
.venv/
venv/
env/

# OS / editor artifacts
.DS_Store
Thumbs.db
.vscode/
# Raw data � documented by README, file itself not versioned
data/raw/*
!data/raw/README.md
# Generated parquet artifacts (regenerable by re-running the parser)
data/processed/*.parquet

# Editable-install metadata (regenerated by pip install -e .)
*.egg-info/
